# Copy to .env and fill in values from `npx supabase status` after `npx supabase start`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=

# Frontend: for Supabase Realtime (cache invalidation). Use anon key from supabase status.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
